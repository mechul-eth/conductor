# Environment and secrets
.env
.env.*
!.env.example

# OS files
.DS_Store
Thumbs.db

# IDE state files at the REPO ROOT only (bootstrap generates these per IDE).
# Leading slash anchors the pattern so the template versions inside
# conductor-core/activation/{ide}/ are NOT filtered.
# See conductor-core/activation/README.md for which IDEs use which files.
/.cursorrules
/.windsurfrules
/.aider.conf.yml
/codex.md
/GEMINI.md
/CLAUDE.md
/CONVENTIONS.md
/AGENTS.md
/.vscode/

# Conductor local session state (user data, never committed)
.conductor/

# Layer 1 libraries — these are git submodules
# Run: git submodule update --init --recursive
# Or clone with: git clone --recurse-submodules
# agency-agents/ and gstack/ are small (~5MB, ~28MB).
# promptfoo/ is large (~750MB due to docs site) — only init if you need validation.

# Dependencies
node_modules/
__pycache__/
.venv/
*.egg-info/
*.pyc

# Build outputs
dist/
build/
*.tgz

# Temporary files
/tmp/
*.tmp

# Test run logs (generated by conductor-core/test/conductor-test-runner.sh)
conductor-core/test/test-run_*.log

# Root-level utility scripts (not part of the project)
/*.py
